COLUMN TABLE india_db_master_businesspartner (
  createdAt TIMESTAMP,
  createdBy NVARCHAR(255),
  modifiedAt TIMESTAMP,
  modifiedBy NVARCHAR(255),
  NODE_KEY NVARCHAR(50) NOT NULL,
  BP_ROLE NVARCHAR(2),
  EMAIL_ADDRESS NVARCHAR(105),
  PHONE_NUMBER NVARCHAR(32),
  FAX_NUMBER NVARCHAR(32),
  WEB_ADDRESS NVARCHAR(44),
  ADDRESS_GUID_NODE_KEY NVARCHAR(50),
  BP_ID NVARCHAR(16),
  COMPANY_NAME NVARCHAR(250),
  PRIMARY KEY(NODE_KEY)
)