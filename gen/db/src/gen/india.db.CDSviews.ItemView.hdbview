VIEW india_db_CDSviews_ItemView AS SELECT
  PARENT_KEY_1.PARTNER_GUID_NODE_KEY AS Vendor,
  poitems_0.PRODUCT_GUID_NODE_KEY AS ProductId,
  poitems_0.CURRENCY_CODE AS Correncycode,
  poitems_0.NET_AMOUNT AS NetAmount,
  poitems_0.TAX_AMOUNT AS TexAmount,
  PARENT_KEY_1.OVERALL_STATUS AS POStatus
FROM (india_db_transaction_poitems AS poitems_0 LEFT JOIN india_db_transaction_purchaseorder AS PARENT_KEY_1 ON poitems_0.PARENT_KEY_NODE_KEY = PARENT_KEY_1.NODE_KEY)