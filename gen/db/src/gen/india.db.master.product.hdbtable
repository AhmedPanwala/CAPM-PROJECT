COLUMN TABLE india_db_master_product (
  NODE_KEY NVARCHAR(50) NOT NULL,
  PRODUCT_ID NVARCHAR(28),
  TYPE_CODE NVARCHAR(2),
  CATEGORY NVARCHAR(32),
  DESCRIPTION NVARCHAR(255),
  SUPPLIER_GUID_NODE_KEY NVARCHAR(50),
  TAX_TARIF_CODE INTEGER,
  MEASURE_UNIT NVARCHAR(2),
  WEIGHT_MEASURE DECIMAL,
  WEIGHT_UNIT NVARCHAR(2),
  CURRENCY_CODE NVARCHAR(4),
  PRICE DECIMAL,
  WIDTH DECIMAL,
  "DEPTH" DECIMAL,
  HEIGHT DECIMAL,
  DIM_UNIT NVARCHAR(2),
  PRIMARY KEY(NODE_KEY)
)