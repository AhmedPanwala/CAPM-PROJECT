COLUMN TABLE india_db_transaction_purchaseorder (
  CURRENCY_CODE NVARCHAR(3),
  GROSS_AMOUNT DECIMAL(15, 2),
  NET_AMOUNT DECIMAL(15, 2),
  TAX_AMOUNT DECIMAL(15, 2),
  NODE_KEY NVARCHAR(50) NOT NULL,
  PO_ID NVARCHAR(24),
  PARTNER_GUID_NODE_KEY NVARCHAR(50),
  LIFECYCLE_STATUS NVARCHAR(1),
  OVERALL_STATUS NVARCHAR(1),
  PRIMARY KEY(NODE_KEY)
)