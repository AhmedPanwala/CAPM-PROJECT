COLUMN TABLE india_db_master_address (
  NODE_KEY NVARCHAR(50) NOT NULL,
  CITY NVARCHAR(40),
  POSTAL_CODE NVARCHAR(8),
  STREET NVARCHAR(100),
  BUILDING NVARCHAR(100),
  COUNTRY NVARCHAR(40),
  ADDRESS_TYPE NVARCHAR(44),
  VAL_START_DATE DATE,
  VAL_END_DATE DATE,
  LATITUDE DECIMAL,
  LONGITUDE DECIMAL,
  PRIMARY KEY(NODE_KEY)
)